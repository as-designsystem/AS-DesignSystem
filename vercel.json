{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @as-designsystem/core build && pnpm --filter @as-designsystem/docs build",
  "outputDirectory": "apps/docs/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- apps/docs/ vercel.json middleware.js api/"
}
